# =============================================================================
# TradeAgent Startup Configuration
# =============================================================================
# 这是基础设施启动配置示例文件
# 复制为 .env 并填入实际值

# =============================================================================
# System Settings
# =============================================================================
ENV=development
SERVICE_NAME=tradeagent
LOG_LEVEL=INFO
DEBUG=false
ALLOW_TRADING=true

# JWT Secret Key - Generate a strong key for production!
# Generate with: python -c "import secrets; print(secrets.token_hex(64))"
JWT_SECRET_KEY=

# Allow default admin access (only for development)
ALLOW_DEFAULT_ADMIN=false

# =============================================================================
# Kafka Settings
# =============================================================================
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CLIENT_ID=tradeagent
KAFKA_CONSUMER_GROUP=tradeagent
KAFKA_AUTO_OFFSET_RESET=latest
KAFKA_ENABLE_AUTO_COMMIT=true
KAFKA_MAX_POLL_RECORDS=100
KAFKA_SESSION_TIMEOUT_MS=30000
KAFKA_HEARTBEAT_INTERVAL_MS=10000

# =============================================================================
# Redis Settings
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=50
REDIS_SOCKET_TIMEOUT=5.0
REDIS_SOCKET_CONNECT_TIMEOUT=5.0
REDIS_RETRY_ON_TIMEOUT=true

# =============================================================================
# PostgreSQL Settings
# =============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=tradeagent
POSTGRES_USERNAME=postgres
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_MIN_CONNECTIONS=5
POSTGRES_MAX_CONNECTIONS=20
POSTGRES_CONNECTION_TIMEOUT=30
POSTGRES_COMMAND_TIMEOUT=60

# =============================================================================
# ClickHouse Settings
# =============================================================================
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=9000
CLICKHOUSE_DATABASE=tradeagent
CLICKHOUSE_USERNAME=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_MIN_CONNECTIONS=5
CLICKHOUSE_MAX_CONNECTIONS=20
CLICKHOUSE_CONNECTION_TIMEOUT=30
CLICKHOUSE_SEND_RECEIVE_TIMEOUT=300

# =============================================================================
# LLM Settings
# =============================================================================
LLM_OPENAI_API_KEY=
LLM_OPENAI_BASE_URL=https://api.openai.com/v1
LLM_ANTHROPIC_API_KEY=
LLM_MINIMAX_API_KEY=
LLM_MINIMAX_BASE_URL=https://api.minimax.chat/v1
LLM_DEFAULT_MODEL=gpt-4o

# =============================================================================
# Third-party API Keys
# =============================================================================
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

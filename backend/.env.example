# ============================================
# 数据源 API Key 配置
# ============================================
# 复制此文件为 .env 并填入真实凭证
# 或直接在环境中设置这些变量
# ============================================

# ============================================
# Twitter/X API
# ============================================
# 获取地址：https://developer.twitter.com/en/docs/twitter-api
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=

# ============================================
# CryptoPanic API
# ============================================
# 获取地址：https://cryptopanic.com/developers/api/
CRYPTOPANIC_API_KEY=

# ============================================
# Whale Alert API
# ============================================
# 获取地址：https://docs.whale-alert.io/
WHALE_ALERT_API_KEY=

# ============================================
# 其他可选配置
# ============================================
# Twitter 监控账号列表（逗号分隔）
# TWITTER_MONITOR_ACCOUNTS=elonmusk,cz_binance,VitalikButerin,saylor,BarrySilbert,binance,okx,coinbase,SBF_FTX

# 数据采集间隔（秒）
# DATA_FETCH_INTERVAL=60

# ============================================
# QQ 实时监控 (NapCatQQ)
# ============================================
# 推荐使用 NapCatQQ，基于 QQ NT 版本
# 下载: https://github.com/NapNeko/NapCatQQ/releases
# 文档: https://napcat.nepsno.com/
#
# 1. 安装 NapCatQQ 并扫码登录
# 2. 开启 WebSocket 服务 (默认端口 3001)
# 3. 加入要监控的 QQ 群
# 4. 配置以下环境变量

# 是否使用模拟模式 (true/false)
QQ_USE_MOCK=true

# NapCatQQ WebSocket 地址
QQ_WS_URL=ws://127.0.0.1:3001

# 要监控的群号，逗号分隔
QQ_WATCH_GROUPS=

# NapCat 访问令牌 (可选)
QQ_ACCESS_TOKEN=

# ============================================
# Telegram (可选)
# ============================================
# 要开启 QQ → Telegram 消息转发，配置以下：
# 创建 Bot: https://t.me/BotFather
# 获取 ChatID: https://t.me/username_to_id_bot
#
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# ============================================
# 说明
# ============================================
# - 如果没有 API Key，系统会自动使用模拟数据
# - 配置完成后，运行以下命令验证：
#   PYTHONPATH=. python3 services/data_service/test_multi_source.py
# - 完整配置指南：doc/交易系统/05_Data/05.10_数据源API配置指南.md

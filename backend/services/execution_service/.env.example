# Execution Service Configuration
# Copy this file to .env and update values

# ====================
# General Settings
# ====================

# Use mock adapter instead of real exchange (true/false)
EXECUTION_MOCK=true

# ====================
# Binance Configuration
# ====================

# Binance API credentials (for real trading)
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# Use Binance testnet (true/false)
BINANCE_TESTNET=true

# Market type: spot, usdt_futures, coin_futures
EXECUTION_MARKET_TYPE=spot

# ====================
# Kafka Configuration
# ====================

# Kafka broker addresses
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ====================
# Risk Management
# ====================

# Maximum total position value (in quote currency, e.g., USDT)
RISK_MAX_POSITION_VALUE=10000

# Maximum number of concurrent positions
RISK_MAX_POSITION_COUNT=10

# Maximum allowed leverage
RISK_MAX_LEVERAGE=10

# Leverage warning threshold (warning logged when above this)
RISK_WARNING_LEVERAGE=5

# Maximum daily loss percentage (0.1 = 10%)
RISK_MAX_DAILY_LOSS_PCT=0.1

# Initial capital for daily loss calculation
RISK_INITIAL_CAPITAL=10000

# Default cooldown period between trades (in seconds)
RISK_DEFAULT_COOLDOWN=300
